APP_NAME=VnPy Web Bridge
APP_ENV=development
LOG_LEVEL=INFO

VNPY_RPC_REQ_ADDRESS=tcp://127.0.0.1:2014
VNPY_RPC_PUB_ADDRESS=tcp://127.0.0.1:4102
VNPY_GATEWAY_NAME=CTP
VNPY_RPC_TIMEOUT_MS=10000

WEB_TRADE_ENABLED=false
DEFAULT_GATEWAY_NAME=CTP
ORDER_CONFIRM_REQUIRED=true
TRADE_REFERENCE_PREFIX=web_bridge

JWT_SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480
AUTH_USERS_JSON=[]
QUESTDB_PG_DSN=postgresql://admin:quest@127.0.0.1:8812/qdb
QUESTDB_ILP_CONF=http::addr=127.0.0.1:9000;
QUESTDB_TICK_PERSIST_ENABLED=true
QUESTDB_TICK_QUEUE_SIZE=100000
QUESTDB_TICK_BATCH_SIZE=1000
QUESTDB_TICK_FLUSH_INTERVAL_MS=500
QUESTDB_TICK_RETRY_MAX_SECONDS=60
QUESTDB_TICK_SPOOL_DIR=logs/tick-spool
QUESTDB_TICK_SPOOL_MAX_BYTES=10737418240
QUESTDB_TICK_SPOOL_SEGMENT_BYTES=67108864
QUESTDB_TICK_SPOOL_FSYNC=false
QUESTDB_TICK_ERROR_LOG_INTERVAL_SECONDS=60
DATABASE_URL=postgresql://vnpy:vnpy@127.0.0.1:5432/vnpy

MONITOR_ENABLED=false
MONITOR_INTERVAL_SECONDS=15
MONITOR_FAILURE_THRESHOLD=3
MONITOR_RECOVERY_THRESHOLD=2
MONITOR_STARTUP_GRACE_SECONDS=120
MONITOR_FLAP_SEND_GRACE_SECONDS=45
MONITOR_FLAP_RECOVERY_GRACE_SECONDS=60
MONITOR_CRITICAL_REMINDER_MINUTES=0
MONITOR_STATE_PATH=/app/logs/monitor/state.json
MONITOR_EVENTS_PATH=/app/logs/monitor/events.jsonl
MONITOR_MAINTENANCE_PATH=/app/logs/watchdog/maintenance.json
MONITOR_MAX_SILENCE_SECONDS=86400
MONITOR_TICK_STALE_SECONDS=120
MONITOR_HTTP_5XX_THRESHOLD=5
MONITOR_HTTP_5XX_WINDOW_SECONDS=300
MONITOR_TRADE_FAILURE_THRESHOLD=3
MONITOR_TRADE_FAILURE_WINDOW_SECONDS=300
MONITOR_EXPECTED_STRATEGIES=

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_SEND_LEVELS=critical,warning
TELEGRAM_HTTP_TIMEOUT_SECONDS=8
TELEGRAM_TRADE_EVENTS_ENABLED=false

WATCHDOG_ENABLED=true
WATCHDOG_INTERVAL_SECONDS=15
WATCHDOG_FAILURE_THRESHOLD=3
WATCHDOG_RECOVERY_THRESHOLD=2
WATCHDOG_CONTAINER_NAME=vnpy-web-bridge
WATCHDOG_LIVENESS_URL=http://127.0.0.1:8080/api/health/live
WATCHDOG_LOG_DIR=/Users/fujun/services/vnpy-web-bridge/logs
WATCHDOG_STATE_PATH=/Users/fujun/services/vnpy-web-bridge/logs/watchdog/state.json
WATCHDOG_EVENTS_PATH=/Users/fujun/services/vnpy-web-bridge/logs/watchdog/events.jsonl
WATCHDOG_MAINTENANCE_FILE=/Users/fujun/services/vnpy-web-bridge/logs/watchdog/maintenance.json
WATCHDOG_DISK_WARNING_PERCENT=85
WATCHDOG_DISK_CRITICAL_PERCENT=95
WATCHDOG_HTTP_TIMEOUT_SECONDS=3

RISK_MAX_ORDER_VOLUME=1
RISK_MAX_SYMBOL_POSITION=5
RISK_MAX_DAILY_LOSS=1000
RISK_PRICE_PROTECTION_PERCENT=3
RISK_ALLOWED_EXCHANGES=SHFE,DCE,CZCE,CFFEX,INE,GFEX
RISK_ALLOWED_SYMBOLS=
RISK_BLOCKED_SYMBOLS=
RISK_TRADING_TIME_CHECK_ENABLED=false

# Frozen STATIC_CORE_EQUAL commodity strategy. Keep disabled until the RPC
# gateway is bound to exactly one allow-listed SimNow account.
COMMODITY_SIMNOW_ENABLED=false
COMMODITY_SIMNOW_GATEWAY_NAME=CTP
COMMODITY_SIMNOW_ACCOUNT_HASHES=
COMMODITY_SIMNOW_TRUSTED_PUBLIC_KEYS_JSON={}
COMMODITY_SIMNOW_STATE_PATH=logs/commodity-simnow/state.json
# Only official_forward batches use this boundary; simnow_shakedown can execute today.
COMMODITY_SIMNOW_MIN_SOURCE_MONTH=2026-08
COMMODITY_SIMNOW_MAX_CHILD_ORDER_LOTS=10
COMMODITY_SIMNOW_MAX_ORDERS_PER_PHASE=128
COMMODITY_SIMNOW_MAX_QUOTE_AGE_SECONDS=5
COMMODITY_SIMNOW_MAX_SPREAD_TICKS=4
COMMODITY_SIMNOW_AUTO_DISPATCH_ENABLED=true
COMMODITY_SIMNOW_AUTO_DISPATCH_INTERVAL_SECONDS=1
COMMODITY_SIMNOW_AUTO_DISPATCH_RECONCILE_GRACE_SECONDS=30
COMMODITY_SIMNOW_SUBMISSION_OUTCOME_GRACE_SECONDS=30
COMMODITY_SIMNOW_SUBMISSION_OUTCOME_MIN_EMPTY_SNAPSHOTS=3
# Disabled by default. SimNow-shakedown-only, manual passive-limit acceptance.
COMMODITY_SIMNOW_ACCEPTANCE_PASSIVE_LIMIT_ENABLED=false
COMMODITY_SIMNOW_ACCEPTANCE_PASSIVE_LIMIT_TTL_SECONDS=15
COMMODITY_SIMNOW_ACCEPTANCE_MAX_TOTAL_ORDERS=2
COMMODITY_SIMNOW_ACCEPTANCE_MAX_TOTAL_LOTS=2
# Atomically replace this signed v2 batch file; one-click start and the worker consume it.
COMMODITY_SIMNOW_TEMPLATE_BATCH_PATH=
# Optional read-only signed position-manager snapshot; it never grants dispatch authority.
COMMODITY_POSITION_MANAGER_SHADOW_PATH=
# Local continuity evidence for the last verified position-manager snapshot.
COMMODITY_POSITION_MANAGER_SHADOW_STATE_PATH=logs/commodity-simnow/position-manager-shadow-state.json
COMMODITY_POSITION_MANAGER_SIMNOW_SHAKEDOWN_ENABLED=false
COMMODITY_POSITION_MANAGER_SIMNOW_STATE_PATH=logs/commodity-simnow/position-manager-shakedown.json
COMMODITY_POSITION_MANAGER_SIMNOW_MAX_SELECTED_PRODUCTS=10
COMMODITY_POSITION_MANAGER_SIMNOW_AUTO_DISPATCH_ENABLED=false
# SHFE contracts fail closed no later than the first day of their delivery month.
COMMODITY_SIMNOW_DELIVERY_MONTH_CUTOFF_DAY=1
# INE crude oil expires before its delivery month; stop carrying it from this prior-month day.
COMMODITY_SIMNOW_SC_PRE_DELIVERY_CUTOFF_DAY=15
