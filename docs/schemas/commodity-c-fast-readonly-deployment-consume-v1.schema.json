{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:vnpy-web-bridge:schema:commodity-c-fast-readonly-deployment-consume-v1",
  "title": "C_FAST readonly deployment release consume marker v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "candidate_id",
    "release_id",
    "attempt_id",
    "release_raw_sha256",
    "release_canonical_sha256",
    "consumed_at",
    "trusted_keyring_sha256",
    "source_commit_sha",
    "questdb_image_digest",
    "evidence_bundle_index_sha256",
    "custody_identity_sha256",
    "custody_path_sha256",
    "replay_allowed",
    "deployment_executed"
  ],
  "properties": {
    "schema_version": {
      "const": "commodity_c_fast_readonly_deployment_consume_v1"
    },
    "candidate_id": {
      "const": "C_FAST_CROSS_SECTION_NEUTRAL"
    },
    "release_id": {
      "$ref": "#/$defs/id"
    },
    "attempt_id": {
      "type": "string",
      "pattern": "^attempt-[0-9a-f]{64}$"
    },
    "release_raw_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "release_canonical_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "consumed_at": {
      "$ref": "#/$defs/dateTime"
    },
    "trusted_keyring_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "source_commit_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "questdb_image_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "evidence_bundle_index_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "custody_identity_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "custody_path_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "replay_allowed": {
      "const": false
    },
    "deployment_executed": {
      "const": false
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]{8,128}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  }
}
