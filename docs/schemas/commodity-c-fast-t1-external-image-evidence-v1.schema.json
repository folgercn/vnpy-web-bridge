{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:vnpy-web-bridge:schema:commodity-c-fast-t1-external-image-evidence-v1",
  "title": "C_FAST T1 external OCI image evidence v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "capture_kind",
    "captured_at",
    "producer",
    "source_commit_sha",
    "source_archive_sha256",
    "build",
    "image"
  ],
  "properties": {
    "schema_version": {
      "const": "commodity_c_fast_t1_external_image_evidence_v1"
    },
    "capture_kind": {
      "const": "registry_manifest_and_image_export_v1"
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool",
        "tool_version"
      ],
      "properties": {
        "tool": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9._+-]+$"
        },
        "tool_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9._+-]+$"
        }
      }
    },
    "source_commit_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "source_archive_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "platform",
        "context_root",
        "containerfile_sha256",
        "base_image_digest",
        "direct_dependencies"
      ],
      "properties": {
        "platform": {
          "const": "linux/amd64"
        },
        "context_root": {
          "const": "."
        },
        "containerfile_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "base_image_digest": {
          "$ref": "#/$defs/ociDigest"
        },
        "direct_dependencies": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "cryptography",
            "jsonschema",
            "psycopg[binary]",
            "referencing"
          ],
          "properties": {
            "cryptography": {
              "const": "48.0.0"
            },
            "jsonschema": {
              "const": "4.26.0"
            },
            "psycopg[binary]": {
              "const": "3.2.3"
            },
            "referencing": {
              "const": "0.37.0"
            }
          }
        }
      }
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reference",
        "digest",
        "id",
        "export_sha256",
        "rootfs_layer_digests",
        "config",
        "bundle_files",
        "forbidden_path_matches",
        "unexpected_bundle_paths",
        "signer_or_private_key_paths"
      ],
      "properties": {
        "reference": {
          "type": "string",
          "pattern": "^[^@\\s]+@sha256:[0-9a-f]{64}$"
        },
        "digest": {
          "$ref": "#/$defs/ociDigest"
        },
        "id": {
          "$ref": "#/$defs/ociDigest"
        },
        "export_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "rootfs_layer_digests": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/ociDigest"
          }
        },
        "config": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "user",
            "working_dir",
            "entrypoint",
            "relevant_environment",
            "labels"
          ],
          "properties": {
            "user": {
              "const": "65532:65532"
            },
            "working_dir": {
              "const": "/opt/c-fast-t1"
            },
            "entrypoint": {
              "type": "array",
              "prefixItems": [
                {
                  "const": "python"
                },
                {
                  "const": "-I"
                },
                {
                  "const": "/opt/c-fast-t1/scripts/commodity_c_fast_t1_one_shot.py"
                }
              ],
              "items": false,
              "minItems": 3,
              "maxItems": 3
            },
            "relevant_environment": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "PYTHONDONTWRITEBYTECODE",
                "PYTHONUNBUFFERED"
              ],
              "properties": {
                "PYTHONDONTWRITEBYTECODE": {
                  "const": "1"
                },
                "PYTHONUNBUFFERED": {
                  "const": "1"
                }
              }
            },
            "labels": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "io.vnpy-web-bridge.c-fast-t1.authority-granted",
                "io.vnpy-web-bridge.c-fast-t1.one-shot-runtime",
                "org.opencontainers.image.revision",
                "org.opencontainers.image.title"
              ],
              "properties": {
                "io.vnpy-web-bridge.c-fast-t1.authority-granted": {
                  "const": "false"
                },
                "io.vnpy-web-bridge.c-fast-t1.one-shot-runtime": {
                  "const": "true"
                },
                "org.opencontainers.image.revision": {
                  "type": "string",
                  "pattern": "^[0-9a-f]{40}$"
                },
                "org.opencontainers.image.title": {
                  "const": "vnpy-web-bridge C_FAST T1 one-shot runner"
                }
              }
            }
          }
        },
        "bundle_files": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "/opt/c-fast-t1/docs/schemas/commodity-c-fast-l1-l5-audit-manifest-v2.schema.json",
            "/opt/c-fast-t1/docs/schemas/commodity-c-fast-l1-l5-audit-v1.schema.json",
            "/opt/c-fast-t1/docs/schemas/commodity-c-fast-l1-l5-audit-v2.schema.json",
            "/opt/c-fast-t1/docs/schemas/commodity-c-fast-questdb-readonly-proof-v1.schema.json",
            "/opt/c-fast-t1/docs/schemas/commodity-c-fast-t1-consume-v1.schema.json",
            "/opt/c-fast-t1/docs/schemas/commodity-c-fast-t1-one-shot-release-v1.schema.json",
            "/opt/c-fast-t1/docs/schemas/commodity-c-fast-t1-terminal-seal-v1.schema.json",
            "/opt/c-fast-t1/scripts/commodity_c_fast_l1_l5_audit.py",
            "/opt/c-fast-t1/scripts/commodity_c_fast_t1_one_shot.py"
          ],
          "properties": {
            "/opt/c-fast-t1/docs/schemas/commodity-c-fast-l1-l5-audit-manifest-v2.schema.json": {
              "$ref": "#/$defs/sha256"
            },
            "/opt/c-fast-t1/docs/schemas/commodity-c-fast-l1-l5-audit-v1.schema.json": {
              "$ref": "#/$defs/sha256"
            },
            "/opt/c-fast-t1/docs/schemas/commodity-c-fast-l1-l5-audit-v2.schema.json": {
              "$ref": "#/$defs/sha256"
            },
            "/opt/c-fast-t1/docs/schemas/commodity-c-fast-questdb-readonly-proof-v1.schema.json": {
              "$ref": "#/$defs/sha256"
            },
            "/opt/c-fast-t1/docs/schemas/commodity-c-fast-t1-consume-v1.schema.json": {
              "$ref": "#/$defs/sha256"
            },
            "/opt/c-fast-t1/docs/schemas/commodity-c-fast-t1-one-shot-release-v1.schema.json": {
              "$ref": "#/$defs/sha256"
            },
            "/opt/c-fast-t1/docs/schemas/commodity-c-fast-t1-terminal-seal-v1.schema.json": {
              "$ref": "#/$defs/sha256"
            },
            "/opt/c-fast-t1/scripts/commodity_c_fast_l1_l5_audit.py": {
              "$ref": "#/$defs/sha256"
            },
            "/opt/c-fast-t1/scripts/commodity_c_fast_t1_one_shot.py": {
              "$ref": "#/$defs/sha256"
            }
          }
        },
        "forbidden_path_matches": {
          "type": "array",
          "maxItems": 0
        },
        "unexpected_bundle_paths": {
          "type": "array",
          "maxItems": 0
        },
        "signer_or_private_key_paths": {
          "type": "array",
          "maxItems": 0
        }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "ociDigest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
