{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:vnpy-web-bridge:schema:commodity-c-fast-t1-image-attestation-v1",
  "title": "C_FAST T1 external image attestation v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "source_commit_sha",
    "source_archive_sha256",
    "external_evidence_sha256",
    "evidence_captured_at",
    "containerfile_sha256",
    "base_image_digest",
    "image_reference",
    "image_digest",
    "image_id",
    "image_export_sha256",
    "rootfs_layer_digests",
    "runtime_bundle_sha256",
    "checks",
    "image_built_here",
    "authority_granted",
    "deployment_mutation_authorized",
    "production_query_authorized",
    "execution_quality_collection_authorized",
    "order_submission_authorized",
    "position_mutation_authorized",
    "dispatch_authorized",
    "database_mutation_authorized",
    "dynamic_selection_allowed",
    "database_mutations",
    "orders_sent",
    "positions_modified",
    "dispatch_changed"
  ],
  "properties": {
    "schema_version": {
      "const": "commodity_c_fast_t1_image_attestation_v1"
    },
    "status": {
      "const": "EXTERNAL_BUILD_EVIDENCE_VERIFIED_NOT_IMAGE_BUILT_HERE"
    },
    "source_commit_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "source_archive_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "external_evidence_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "evidence_captured_at": {
      "type": "string",
      "format": "date-time"
    },
    "containerfile_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "base_image_digest": {
      "$ref": "#/$defs/ociDigest"
    },
    "image_reference": {
      "type": "string",
      "pattern": "^[^@\\s]+@sha256:[0-9a-f]{64}$"
    },
    "image_digest": {
      "$ref": "#/$defs/ociDigest"
    },
    "image_id": {
      "$ref": "#/$defs/ociDigest"
    },
    "image_export_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "rootfs_layer_digests": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": {
        "$ref": "#/$defs/ociDigest"
      }
    },
    "runtime_bundle_sha256": {
      "type": "object",
      "minProperties": 9,
      "maxProperties": 9,
      "additionalProperties": {
        "$ref": "#/$defs/sha256"
      }
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exact_git_commit_resolved",
        "git_archive_digest_matched",
        "containerfile_digest_matched",
        "base_image_digest_matched",
        "direct_dependencies_matched",
        "immutable_image_reference_matched",
        "oci_revision_matched",
        "non_root_entrypoint_matched",
        "runtime_bundle_hashes_matched",
        "forbidden_and_signer_paths_absent"
      ],
      "properties": {
        "exact_git_commit_resolved": {
          "const": true
        },
        "git_archive_digest_matched": {
          "const": true
        },
        "containerfile_digest_matched": {
          "const": true
        },
        "base_image_digest_matched": {
          "const": true
        },
        "direct_dependencies_matched": {
          "const": true
        },
        "immutable_image_reference_matched": {
          "const": true
        },
        "oci_revision_matched": {
          "const": true
        },
        "non_root_entrypoint_matched": {
          "const": true
        },
        "runtime_bundle_hashes_matched": {
          "const": true
        },
        "forbidden_and_signer_paths_absent": {
          "const": true
        }
      }
    },
    "image_built_here": {
      "const": false
    },
    "authority_granted": {
      "const": false
    },
    "deployment_mutation_authorized": {
      "const": false
    },
    "production_query_authorized": {
      "const": false
    },
    "execution_quality_collection_authorized": {
      "const": false
    },
    "order_submission_authorized": {
      "const": false
    },
    "position_mutation_authorized": {
      "const": false
    },
    "dispatch_authorized": {
      "const": false
    },
    "database_mutation_authorized": {
      "const": false
    },
    "dynamic_selection_allowed": {
      "const": false
    },
    "database_mutations": {
      "const": 0
    },
    "orders_sent": {
      "const": 0
    },
    "positions_modified": {
      "const": 0
    },
    "dispatch_changed": {
      "const": false
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "ociDigest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
